server {
    listen 443 ssl http2;
    server_name livres.mondomaine.exemple;

    ssl_certificate     /etc/letsencrypt/live/livres.mondomaine.exemple/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/livres.mondomaine.exemple/privkey.pem;

    root /srv/book-manager/public;
    index index.php;

    client_max_body_size 5m;

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~ \.php$ {
        include fastcgi_params;
        fastcgi_pass unix:/run/php/php8.3-fpm.sock; # adapte à ta version de PHP
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
    }

    # Le flux SSE (/api/runs/{id}/events) doit rester non bufferisé.
    location /api/runs/ {
        fastcgi_pass unix:/run/php/php8.3-fpm.sock;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $document_root/index.php;
        fastcgi_buffering off;
        proxy_buffering off;
        add_header X-Accel-Buffering no;
    }

    location ~ /\.(env|git) {
        deny all;
    }
}

server {
    listen 80;
    server_name livres.mondomaine.exemple;
    return 301 https://$host$request_uri;
}
