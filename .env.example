# Copie ce fichier en .env et remplis les valeurs. Ne commite jamais le .env réel.

# Génère avec : php -r 'echo password_hash("ton-mot-de-passe", PASSWORD_DEFAULT), "\n";'
APP_PASSWORD_HASH=

# Jeton d'abonnement Claude.ai (PAS une clé API à la facturation à l'usage).
# Génère-le une fois sur le VPS avec : claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=

# Chemin vers le binaire claude si besoin (sinon "claude" doit être dans le PATH du service worker)
CLAUDE_BINARY=claude

# Dossier où vivent app.db, les livres et les copies de travail temporaires
DATA_DIR=/srv/book-manager/data

# Délai max (secondes) avant qu'un run d'agent soit considéré bloqué et interrompu
RUN_TIMEOUT_SECONDS=600
